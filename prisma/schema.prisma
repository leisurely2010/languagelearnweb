// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  level         Int       @default(1)
  totalXP       Int       @default(0)
  currentStreak Int       @default(0)
  lastLogin     DateTime?
  totalWrongQuestions Int  @default(0)
  totalCorrectedQuestions Int  @default(0)
  // 专项训练统计
  specialTrainingCompleted Int @default(0)
  specialTrainingPerfect  Int @default(0)
  specialTrainingStreak   Int @default(0)
  specialTrainingTypes    String @default("[]") // 记录完成过的训练类型，JSON格式字符串
  specialTrainingTypeCompleted String @default("[]") // 记录完成所有等级的训练类型，JSON格式字符串
  
  // 绘本阅读统计
  storyBooksRead      Int      @default(0)
  storyBooksCompleted Int      @default(0)
  storyBooksPerfect   Int      @default(0)
  storyLanguages      String   @default("[]") // 记录阅读过绘本的语言，JSON格式字符串
  
  learningPaths LearningPath[]
  progress      Progress[]
  achievements  Achievement[]
  posts         Post[]
  comments      Comment[]
  friends       Friendship[]  @relation("UserFriendships")
  friendOf     Friendship[]  @relation("FriendOfUser")
  wrongQuestions WrongQuestion[]
  examAttempts  ExamAttempt[]
  unlockedLevels UnlockedLevel[]
  specialTrainingAttempts SpecialTrainingAttempt[]
  storyAttempts           StoryAttempt[]
}

model LearningPath {
  id          String   @id @default(cuid())
  userId      String
  language    String
  level       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  language    String
  level       Int
  category    String
  duration    Int
  lessons     Lesson[]
  createdAt   DateTime @default(now())
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  content     String
  order       Int
  type        String
  createdAt   DateTime @default(now())
  
  course      Course   @relation(fields: [courseId], references: [id])
  exercises   Exercise[]
}

model Exercise {
  id          String   @id @default(cuid())
  lessonId    String
  type        String
  question    String
  options     String
  answer      String
  feedback    String
  createdAt   DateTime @default(now())
  
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
}

model Progress {
  id          String       @id @default(cuid())
  userId      String
  courseId    String?
  lessonId    String?
  completed   Boolean      @default(false)
  score       Int?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  
  user        User         @relation(fields: [userId], references: [id])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  icon        String
  unlockedAt  DateTime
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
}

model Post {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id])
  comments    Comment[]
}

model Comment {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  content     String
  createdAt   DateTime @default(now())
  
  post        Post     @relation(fields: [postId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Friendship {
  id          String   @id @default(cuid())
  userId      String
  friendId    String
  status      String   @default("pending") // pending, accepted, rejected
  createdAt   DateTime @default(now())
  
  user        User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend      User     @relation("FriendOfUser", fields: [friendId], references: [id], onDelete: Cascade)
  
  @@unique([userId, friendId])
}

model WrongQuestion {
  id                  String   @id @default(cuid())
  userId              String
  // 普通课程字段（保持兼容）
  exerciseId          String?
  courseId            String?
  lessonId            String?
  // 专项训练字段（新增）
  specialTrainingQuestionId String?
  specialTrainingId         String?
  // 通用字段
  question            String
  options             String
  answer              String
  type                String
  source              String   @default("COURSE") // "COURSE" | "SPECIAL_TRAINING"
  consecutiveCorrect  Int      @default(0)
  wrongCount          Int      @default(1)
  lastAttemptedAt     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  user                User     @relation(fields: [userId], references: [id])
  
  @@unique([userId, exerciseId])
  @@unique([userId, specialTrainingQuestionId])
}

// 考试模型 - 每个等级有对应的考试
model Exam {
  id          String   @id @default(cuid())
  language    String
  level       Int
  title       String
  description String
  passingScore Int     @default(60) // 及格分数
  totalQuestions Int  @default(10)
  createdAt   DateTime @default(now())
  
  questions   ExamQuestion[]
  attempts    ExamAttempt[]
}

// 考试题目模型
model ExamQuestion {
  id          String   @id @default(cuid())
  examId      String
  order       Int
  question    String
  options     String   // JSON格式的选项数组
  answer      String
  explanation String?
  createdAt   DateTime @default(now())
  
  exam        Exam     @relation(fields: [examId], references: [id])
  answers     ExamAnswer[]
}

// 考试尝试模型 - 记录用户的考试尝试
model ExamAttempt {
  id          String   @id @default(cuid())
  userId      String
  examId      String
  score       Int?
  passed      Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
  exam        Exam     @relation(fields: [examId], references: [id])
  answers     ExamAnswer[]
}

// 考试答案模型 - 记录用户在某次考试中每道题的答案
model ExamAnswer {
  id              String   @id @default(cuid())
  examAttemptId   String
  examQuestionId  String
  userAnswer      String
  isCorrect       Boolean
  createdAt       DateTime @default(now())
  
  examAttempt     ExamAttempt @relation(fields: [examAttemptId], references: [id])
  examQuestion    ExamQuestion @relation(fields: [examQuestionId], references: [id])
}

// 等级解锁模型 - 记录用户解锁的等级
model UnlockedLevel {
  id          String   @id @default(cuid())
  userId      String
  language    String
  level       Int
  unlockedAt  DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
  
  @@unique([userId, language, level])
}

// 专项训练模型
model SpecialTraining {
  id          String   @id @default(cuid())
  type        String   // "PINYIN_TO_WORDS" | "SYNONYMS" | "ANTONYMS" | "IDIOMS" | "WORD_COLLOCATION" | "FILL_IN_BLANK" | "QUANTIFIERS" | "PUNCTUATION"
  language    String
  level       Int
  title       String
  description String
  createdAt   DateTime @default(now())
  
  questions   SpecialTrainingQuestion[]
  attempts    SpecialTrainingAttempt[]
}

model SpecialTrainingQuestion {
  id          String   @id @default(cuid())
  trainingId  String
  order       Int
  type        String
  question    String   // JSON格式
  answer      String
  explanation String?
  difficulty  Int      @default(3)
  createdAt   DateTime @default(now())
  
  training    SpecialTraining @relation(fields: [trainingId], references: [id])
  answers     SpecialTrainingAnswer[]
}

model SpecialTrainingAttempt {
  id          String   @id @default(cuid())
  userId      String
  trainingId  String
  score       Int?
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  
  user        User              @relation(fields: [userId], references: [id])
  training    SpecialTraining   @relation(fields: [trainingId], references: [id])
  answers     SpecialTrainingAnswer[]
}

model SpecialTrainingAnswer {
  id               String   @id @default(cuid())
  attemptId        String
  questionId       String
  userAnswer       String
  isCorrect        Boolean
  createdAt        DateTime @default(now())
  
  attempt          SpecialTrainingAttempt  @relation(fields: [attemptId], references: [id])
  question         SpecialTrainingQuestion @relation(fields: [questionId], references: [id])
}

model StoryBook {
  id          String   @id @default(cuid())
  language    String
  level       Int
  title       String
  description String
  content     String
  coverImage  String?
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())

  questions   StoryQuestion[]
  attempts    StoryAttempt[]
}

model StoryQuestion {
  id          String   @id @default(cuid())
  storyId     String
  order       Int
  type        String   @default("CHOICE")
  question    String
  options     String?
  answer      String
  explanation String?
  difficulty  Int      @default(3)
  createdAt   DateTime @default(now())

  story       StoryBook     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  answers     StoryAnswer[]
}

model StoryAttempt {
  id          String   @id @default(cuid())
  userId      String
  storyId     String
  score       Int?
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  user        User       @relation(fields: [userId], references: [id])
  story       StoryBook  @relation(fields: [storyId], references: [id])
  answers     StoryAnswer[]
}

model StoryAnswer {
  id              String         @id @default(cuid())
  attemptId       String
  questionId      String
  userAnswer      String
  isCorrect       Boolean
  createdAt       DateTime       @default(now())

  attempt         StoryAttempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question        StoryQuestion  @relation(fields: [questionId], references: [id])
}
